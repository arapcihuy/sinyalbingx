1|/**
2| * TRADENTIX PRO → BingX Bridge V2
3| * Cloudflare Worker — GRATIS, gak perlu VPS
4| * 
5| * FITUR:
6| * ✅ Dynamic sizing — otomatis sesuaikan sama saldo futures
7| * ✅ Auto leverage — aman, gak over-leverage
8| * ✅ Trailing SL — SL ikut naik kalo harga udah profit
9| * ✅ Paper mode — testing aman
10| * 
11| * Cara deploy:
12| * 1. Buka https://dash.cloudflare.com → Workers & Pages
13| * 2. Create Worker → copas code ini → Deploy
14| * 3. Dapet URL: https://namamu.workers.dev
15| * 4. Di TradingView alert: set Webhook URL ke URL itu
16| * 
17| * Mode PAPER: default true — aman buat testing
18| * Ubah PAPER_MODE = false kalo mau real trading
19| * 
20| * UNTUK TRAILING SL LANJUTAN:
21| * Worker ini support cron trigger. Setup Cron Triggers di Cloudflare:
22| * Settings → Triggers → Cron: every 1 minute (setiap 1 menit)
23| * Worker bakal auto-update trailing SL untuk posisi aktif.
24| */
25|
26|// ⚙️ KONFIGURASI
27|const CONFIG = {
28|  BINGX_API_KEY:        '4SpTFy...qt8Q',
29|  REDACTED_SECRET_KEY:     'HK5P3JWf059hq0k5JREnxAUytlwb3AIDPGmQbG7uQyfRJueZNGeAvcVOBhd9eUdEJnfTppXDPHoLrbgTVg',
30|  REDACTED_WEBHOOK_SECRET:       'REDACTED_WEBHOOK_SECRET',
31|  PAPER_MODE:           true,          // true = testing
32|  RISK_PER_TRADE:       2,             // % saldo per trade (1-5%)
33|  MAX_LEVERAGE:         10,            // maksimal leverage
34|  TRAIL_ACTIVATE_PCT:   1.0,           // trail aktif setelah profit X%
35|  TRAIL_OFFSET_ATR:     1.5,           // jarak trailing dari harga (ATR)
36|};
37|
38|// ====== KV Namespace binding (untuk tracking posisi) ======
39|// Di Cloudflare dashboard: Workers → KV → Create namespace "POSITIONS"
40|// Bind ke worker dengan variable name "POSITIONS"
41|// let POSITIONS;
42|
43|export default {
44|  async fetch(request, env) {
45|    // Support Cron Trigger (Cloudflare Cron Triggers)
46|    const url = new URL(request.url);
47|    if (url.pathname === '/__cron' || request.method === 'CRON') {
48|      return await handleCron(env);
49|    }
50|
51|    if (request.method === 'OPTIONS') {
52|      return new Response('OK', { headers: cors() });
53|    }
54|
55|    if (request.method !== 'POST') {
56|      return new Response('Method not allowed', { status: 405, headers: cors() });
57|    }
58|
59|    try {
60|      const data = await request.json();
61|      console.log('[INCOMING]', JSON.stringify(data));
62|
63|      if (data.secret !== CONFIG.REDACTED_WEBHOOK_SECRET) {
64|        return new Response('Unauthorized', { status: 401, headers: cors() });
65|      }
66|
67|      // Handle CLOSE signal
68|      if (data.action === 'CLOSE') {
69|        const result = await closePosition(data, env);
70|        return jsonResponse(result);
71|      }
72|
73|      const result = await handleSignal(data, env);
74|      return jsonResponse(result);
75|
76|    } catch (err) {
77|      console.error('[ERROR]', err);
78|      return jsonResponse({ error: err.message }, 500);
79|    }
80|  },
81|};
