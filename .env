# ============================================================
#  KONFIGURASI TRADING
# ============================================================
# Pair yang diperdagangkan (format BingX Futures)
SYMBOL=BTC-USDT

# Leverage (1-100, sesuaikan dengan akun Anda)
LEVERAGE=10

# Risk per trade dalam % dari balance (misal: 1.5 = 1.5%)
RISK_PERCENT=1.5

# Mode TP/SL:
#   "pinescript" = TP/SL dikirim dari TradingView alert (nilai harga)
#   "percent"    = TP/SL dihitung otomatis dari entry price
TP_SL_MODE=pinescript

# Jika mode "percent": berapa % TP dan SL dari harga entry
TP_PERCENT=3.0
SL_PERCENT=1.5

# Tipe order: MARKET atau LIMIT
ORDER_TYPE=MARKET

# ============================================================
#  SERVER
# ============================================================
PORT=9000
HOST=0.0.0.0
