// ============================================================
//  TEMPLATE WEBHOOK ALERT — TradingView → BingX
//  Tambahkan blok alertcondition ini ke Pine Script Anda
//  Ganti YOUR_SECRET dengan nilai WEBHOOK_SECRET di .env
// ============================================================

// ─── Contoh variabel sinyal dari strategi Anda ───
// (Sesuaikan dengan nama variabel di Pine Script Anda sendiri)

// Asumsi Anda punya variabel seperti ini dari strategi:
//   longSignal  = kondisi untuk BUY
//   shortSignal = kondisi untuk SELL
//   tp_level    = harga Take Profit
//   sl_level    = harga Stop Loss

// ─── Payload JSON untuk BUY (LONG) ───
// Format ini yang akan dikirim ke webhook server Anda

// Alert Message untuk BUY:
// {
//   "secret": "YOUR_SECRET",
//   "action": "BUY",
//   "symbol": "BTC-USDT",
//   "price": {{close}},
//   "tp": <nilai_tp_anda>,
//   "sl": <nilai_sl_anda>,
//   "leverage": 20,          // Opsional: ganti leverage default
//   "margin_mode": "ISOLATED" // Opsional: ISOLATED atau CROSSED
// }

// ─── Cara pakai ───
// 1. Di Pine Script Anda, buat alertcondition:

alertcondition(
    longSignal,
    title="BUY Signal",
    message='{"secret":"YOUR_SECRET","action":"BUY","symbol":"BTC-USDT","price":{{close}},"tp":<TP_VALUE>,"sl":<SL_VALUE>,"leverage":20}'
)

alertcondition(
    shortSignal,
    title="SELL Signal",
    message='{"secret":"YOUR_SECRET","action":"SELL","symbol":"BTC-USDT","price":{{close}},"tp":<TP_VALUE>,"sl":<SL_VALUE>}'
)

// ─── Jika TP/SL adalah variabel Pine Script ───
// Misalnya TP dan SL ada sebagai float series:
//   alertcondition(longSignal, title="BUY", message='{"secret":"YOUR_SECRET","action":"BUY","symbol":"BTC-USDT","price":{{close}},"tp":' + str.tostring(tp_level) + ',"sl":' + str.tostring(sl_level) + '}')

// ─── CLOSE / Exit ───
alertcondition(
    exitSignal,
    title="CLOSE Signal",
    message='{"secret":"YOUR_SECRET","action":"CLOSE","symbol":"BTC-USDT"}'
)

// ============================================================
//  CARA SETUP ALERT DI TRADINGVIEW:
//  1. Klik ikon jam alarm (Alerts)
//  2. Klik "+ Create Alert"
//  3. Condition: pilih strategi Anda → pilih alertcondition di atas
//  4. Notifications: centang "Webhook URL"
//  5. Webhook URL: masukkan URL ngrok/VPS Anda + /webhook
//     Contoh: https://abc123.ngrok-free.app/webhook
//  6. Message: KOSONGKAN (sudah diset di alertcondition)
//  7. Klik Create
// ============================================================
