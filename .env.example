# ============================================================
#  BINGX API CREDENTIALS
#  Dapatkan dari: BingX > Account > API Management
#  Izin yang diperlukan: Trade (JANGAN aktifkan Withdraw!)
# ============================================================
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# ============================================================
#  KEAMANAN WEBHOOK
#  Buat password rahasia, masukkan juga di TradingView alert
# ============================================================
WEBHOOK_SECRET=buat_password_rahasia_disini

# ============================================================
#  KONFIGURASI TRADING
# ============================================================
# Pair yang diperdagangkan (format BingX Futures)
SYMBOL=BTC-USDT

# Leverage (1-100, sesuaikan dengan akun Anda)
LEVERAGE=10

# Margin Mode (ISOLATED atau CROSSED)
MARGIN_MODE=ISOLATED

# Risk per trade dalam % dari balance (misal: 1.5 = 1.5%)
RISK_PERCENT=1.5

# Mode TP/SL:
#   "pinescript" = TP/SL dikirim dari TradingView alert (nilai harga)
#   "percent"    = TP/SL dihitung otomatis dari entry price
TP_SL_MODE=pinescript

# Jika mode "percent": berapa % TP dan SL dari harga entry
TP_PERCENT=3.0
SL_PERCENT=1.5

# Tipe order: MARKET atau LIMIT
ORDER_TYPE=MARKET

# ============================================================
#  SERVER
# ============================================================
PORT=5000
HOST=0.0.0.0
